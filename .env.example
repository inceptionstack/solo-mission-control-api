# Server
PORT=3000
LOG_LEVEL=info

# Auth provider: "cognito" or "oidc"
AUTH_PROVIDER=cognito
JWT_ISSUER=https://cognito-idp.us-east-1.amazonaws.com/us-east-1_XXXXXXXXX
JWT_AUDIENCE=
JWKS_URI=

# Custom claims mapping (defaults shown)
CLAIM_MAP_SUB=sub
CLAIM_MAP_EMAIL=email
CLAIM_MAP_GROUPS=cognito:groups
CLAIM_MAP_ACCOUNT_ID=custom:accountId

# CORS
CORS_ORIGIN=*

# AWS
AWS_REGION=us-east-1
CROSS_ACCOUNT_ROLE=
MANAGEMENT_ACCOUNT_ID=
SANDBOX_OU_ID=
SOLO_CONSOLE_DOMAIN=

# DynamoDB
PROMPTS_TABLE=solo-prompts

# Budget
BUDGET_LIMIT=100
